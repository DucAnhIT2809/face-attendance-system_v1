# PostgreSQL (giống chuỗi bạn dùng trong ứng dụng)
DATABASE_URL=postgresql://postgres:1234@localhost:5432/face_attendance_db

# JWT
JWT_SECRET=thay-bang-chuoi-bi-mat-dai-it-nhat-32-ky-tu
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# CORS (frontend Vite mặc định)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Chỉ dev: bật 1 rồi gọi POST /api/auth/bootstrap-dev một lần để tạo gv01/sv01 (mật khẩu 1234). Tắt sau khi xong.
# FACE_ALLOW_BOOTSTRAP=1

# modelcore — nhận diện (ArcFace)
# Thư mục gốc chứa Model_v2/ (package face_pipeline)
MODELCORE_ROOT=/absolute/path/to/Face_system/modelcore
# Tên thư mục con (mặc định Model_v2). Đổi nếu bạn đặt tên khác.
# MODELCORE_MODEL_DIR=Model_v2
# File checkpoint .pth và face_db.pt do bạn train/export
ARCFACE_CHECKPOINT=/absolute/path/to/Face_system/modelcore/Model_v2/arcface_runs/your_model.pth
FACE_EMBEDDING_DB=/absolute/path/to/Face_system/modelcore/Model_v2/arcface_runs/face_db.pt
# Python có torch + ultralytics (thường là venv/conda của modelcore)
MODELCORE_PYTHON=python3

# Root chứa face_db riêng theo từng lớp: <CLASS_EMBEDDING_ROOT>/<class_code>/face_db.pt
CLASS_EMBEDDING_ROOT=/absolute/path/to/Face_system/modelcore/Model_v2/arcface_runs/classes

# Upload ảnh khuôn mặt
# local: lưu vào UPLOAD_ROOT trên máy backend
# s3: lưu lên S3-compatible storage (AWS S3, Cloudflare R2, Supabase S3)
STORAGE_BACKEND=local
UPLOAD_ROOT=uploads

# Nếu dùng S3-compatible storage
# S3_BUCKET=your-bucket
# S3_REGION=ap-southeast-1
# S3_ENDPOINT_URL=https://xxxx.supabase.co/storage/v1/s3
# S3_ACCESS_KEY_ID=your-access-key
# S3_SECRET_ACCESS_KEY=your-secret-key
# S3_PREFIX=face-attendance
# STORAGE_PUBLIC_BASE_URL=https://xxxx.supabase.co/storage/v1/object/public/your-bucket
