{
  "name": "face-system",
  "private": true,
  "description": "Điểm danh khuôn mặt — chạy frontend/backend từ thư mục gốc",
  "scripts": {
    "dev": "npm run dev --prefix frontend",
    "build": "npm run build --prefix frontend",
    "preview": "npm run preview --prefix frontend",
    "backend": "cd backend && python -m uvicorn app.main:app --reload --host 127.0.0.1 --port 8001",
    "backend:lan": "cd backend && python -m uvicorn app.main:app --reload --host 0.0.0.0 --port 8001"
  }
}
